# Server-side (Next.js API routes)
# GEMINI_API_KEY=   # optional — only if you use Gemini flyer routes

# Frontend: local = /api/local/extract | firebase = /api/upload (Admin SDK + Storage + Firestore)
# NEXT_PUBLIC_BACKEND_MODE=local

ADMIN_EMAIL=you@example.com
NEXT_PUBLIC_ADMIN_EMAIL=you@example.com

OPENAI_API_KEY=sk-your-openai-api-key-here
NEXT_PUBLIC_BACKEND_MODE=firebase

# Firebase (client — Firestore reads, etc.)
NEXT_PUBLIC_FIREBASE_API_KEY=your-web-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
# Optional override — leave commented to let the app try all default bucket names
# FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxx

# Branded password-setup links (admin Create user → /auth/action). No trailing slash.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Firebase Admin — use file locally; BASE64 for Vercel (minified JSON, base64-encoded)
FIREBASE_SERVICE_ACCOUNT_PATH=.secrets/your-service-account.json
# FIREBASE_SERVICE_ACCOUNT_JSON_BASE64=

# --- Slack flyer ingest (optional — /api/cron/slack-ingest) ---
# Bot: channels:history, files:read; invite bot to each channel. IDs: C… / G…
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_CHANNEL_IDS=C01234567890
SLACK_BOT_TOKEN_2=
SLACK_CHANNEL_IDS_2=
# SLACK_INGEST_JSON=[{"token":"xoxb-...","channels":["C111","C222"]}]
SLACK_LOOKBACK_DAYS=7
CRON_SECRET=generate-a-long-random-secret

# --- Gmail inbox ingest (Vercel cron /api/cron/gmail-ingest; admin POST /api/admin/gmail-ingest) ---
# Google Cloud OAuth client + refresh token (scope: https://www.googleapis.com/auth/gmail.readonly)
GMAIL_CLIENT_ID=your-client-id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your-client-secret
GMAIL_REFRESH_TOKEN=your-refresh-token
# Optional overrides (defaults: in:inbox newer_than:2d, max 25 messages)
# GMAIL_INGEST_QUERY=in:inbox newer_than:1d
# GMAIL_INGEST_MAX_RESULTS=25
