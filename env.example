# Server-side (Next.js API routes)
GEMINI_API_KEY=your_gemini_key_here
OPENAI_API_KEY=your_openai_key_here

# Frontend toggle (local-first MVP)
# - local: Upload page hits /api/local/extract (writes to data/events.json)
# - firebase: POST /api/upload → Admin SDK → Storage + OpenAI + Firestore `flyers` (no browser Storage CORS)
NEXT_PUBLIC_BACKEND_MODE=local

# Firebase (Web SDK config) — client Firestore reads (feed, etc.)
NEXT_PUBLIC_FIREBASE_API_KEY=your_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
# Optional — only if auto-detection fails; exact name from Google Cloud → Cloud Storage → Buckets
# FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=1234567890
NEXT_PUBLIC_FIREBASE_APP_ID=1:1234567890:web:abcdef123456

# In Firebase Console → Authentication → Sign-in method: enable Email/Password (and optionally disable Google if unused).
# Authorized domains: add localhost and your Vercel domain.

# Admin email (must match the @byu.edu account you register/sign in with). Server-only; used for /admin and upload approvals.
# New profiles get canUpload=false until you toggle them on, except this account (always allowed to upload).
ADMIN_EMAIL=you@byu.edu

# Firebase Admin (server uploads to Storage — required when NEXT_PUBLIC_BACKEND_MODE=firebase and bucket is set)
#
# Option A — file path (simplest locally; .secrets/ is gitignored)
FIREBASE_SERVICE_ACCOUNT_PATH=.secrets/firebase-adminsdk.json
#
# Option B — base64 the JSON file (works in a single .env line with Next.js; avoids dotenv mangling \\n)
#   base64 -i .secrets/firebase-adminsdk.json | tr -d '\n'   # paste result as one line:
# FIREBASE_SERVICE_ACCOUNT_JSON_BASE64=...
#
# Option C — raw JSON string (often breaks in Next: double-quoted .env lines rewrite \\n and corrupt the key)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# --- Optional: Slack flyer ingest (cron or manual GET/POST) ---
# Bot needs channels:history, files:read, and membership in each channel. Use channel IDs (C… / G…), not names.
# Primary workspace:
# SLACK_BOT_TOKEN=xoxb-your-bot-token
# SLACK_CHANNEL_IDS=C0123456789,C0987654321
# Second workspace while waiting for admin approval on another (same app or a separate Slack app):
# SLACK_BOT_TOKEN_2=
# SLACK_CHANNEL_IDS_2=
# Or add more via JSON array (merged after primary + secondary):
# SLACK_INGEST_JSON=[{"token":"xoxb-...","channels":["C111","C222"]}]
# SLACK_LOOKBACK_DAYS=7
# Secure /api/cron/slack-ingest in production (Vercel Cron sends this header automatically when set):
# CRON_SECRET=long-random-string
#
# Optional: set false on a public site so only cron/curl can trigger ingest (Upload page button calls the server action).
# SLACK_ALLOW_UI_SYNC=true
